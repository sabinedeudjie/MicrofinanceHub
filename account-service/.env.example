# =============================================================
#  Account Service — Exemple de variables d'environnement
#  Copiez ce fichier en ".env" et remplissez vos propres valeurs.
#    cp .env.example .env
# =============================================================

# --- Serveur --------------------------------------------------
ACCOUNT_SERVICE_PORT=8083

# --- Config Server --------------------------------------------
CONFIG_SERVER_URL=http://localhost:8080

# --- Base de données PostgreSQL -------------------------------
DB_URL=jdbc:postgresql://localhost:5432/microfinancehub
DB_USERNAME=votre_utilisateur_postgres
DB_PASSWORD=votre_mot_de_passe_postgres

# --- Redis (cache) --------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379

# --- RabbitMQ (messaging) -------------------------------------
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# --- Eureka (service discovery) -------------------------------
EUREKA_URL=http://localhost:8761/eureka/

# --- JWT (partagé avec tous les microservices) ----------------
# Minimum 32 caractères, identique dans tous les services
JWT_SECRET=votre_secret_jwt_tres_long_et_securise_32_chars_min

# --- CamPay (Mobile Money) ------------------------------------
# Créez un compte sur https://demo.campay.net pour obtenir vos clés
CAMPAY_BASE_URL=https://demo.campay.net/api
CAMPAY_USERNAME=votre_username_campay
CAMPAY_PASSWORD=votre_password_campay
CAMPAY_WEBHOOK_KEY=votre_cle_webhook_campay
CAMPAY_PERMANENT_TOKEN=votre_token_permanent_campay
