# =============================================================================
# BASE DE DONNÉES PostgreSQL
# =============================================================================
DB_USERNAME=postgres
DB_PASSWORD=votre_mot_de_passe_ici

# =============================================================================
# PREMIER ADMINISTRATEUR (Créé au démarrage)
# =============================================================================
ADMIN_EMAIL=admin@mfh.com
ADMIN_PASSWORD=Admin123!

# =============================================================================
# JWT — SECRET PARTAGÉ (Générer une clé sécurisée)
# =============================================================================
JWT_SECRET=generer_une_cle_securisee_de_64_caracteres_ici

# =============================================================================
# RABBITMQ
# =============================================================================
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# =============================================================================
# EUREKA (Service Discovery)
# =============================================================================
EUREKA_URL=http://registry-service:8761/eureka/

# =============================================================================
# CONFIG SERVER
# =============================================================================
CONFIG_SERVER_URL=http://config-service:8000

# =============================================================================
# TOKEN INTERNE SERVICE-À-SERVICE
# =============================================================================
INTERNAL_API_TOKEN=votre_token_interne_secret_ici

# =============================================================================
# EMAIL (Brevo / SMTP)
# =============================================================================
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=votre_email_smtp_ici
MAIL_PASSWORD=votre_mot_de_passe_smtp_ici
MAIL_FROM=no-reply@mfh.com

# =============================================================================
# SMS — TWILIO
# =============================================================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
SMS_FROM=

# =============================================================================
# CAMPAY — Mobile Money
# =============================================================================
CAMPAY_BASE_URL=https://demo.campay.net/api
CAMPAY_USERNAME=votre_username_campay_ici
CAMPAY_PASSWORD=votre_password_campay_ici
CAMPAY_WEBHOOK_KEY=votre_webhook_key_campay_ici
CAMPAY_PERMANENT_TOKEN=

# =============================================================================
# CLOUDINARY (Stockage documents KYC)
# =============================================================================
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
